# ============================================================
# Vigil — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://vigil:vigil@localhost:5432/vigil

# --- Security ---
# JWT signing key (use a strong random string in production)
JWT_SECRET=change-me-to-a-strong-random-secret

# --- Redis (Optional) ---
# Redis URL for caching and distributed locks
# Leave empty to disable Redis features
REDIS_URL=

# --- Webhooks (Optional) ---
# Slack incoming webhook URL for alerts
SLACK_WEBHOOK_URL=

# Generic webhook URL for alerts
WEBHOOK_URL=

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# --- Monitoring ---
# Enable Prometheus metrics endpoint (/metrics)
PROMETHEUS_ENABLED=true

# --- CORS ---
# Comma-separated list of allowed origins
# For local dev: http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# --- Default Watchlist ---
# Comma-separated list of ticker symbols
WATCHLIST=SPY,QQQ,IWM
